# ---- Database ----
# psycopg3 driver works for both sync (Alembic) and async (app) engines.
DATABASE_URL=postgresql+psycopg://manuals:manuals@localhost:5432/manuals

# ---- Object storage (local filesystem for MVP) ----
STORAGE_DIR=./_storage
MAX_UPLOAD_MB=50

# ---- Provider defaults ----
# LLM (generation) provider can be overridden per chat request.
# Embedding provider is global — switching it requires re-ingesting manuals.
DEFAULT_LLM_PROVIDER=claude          # claude | openai | ollama
DEFAULT_EMBEDDING_PROVIDER=voyage    # voyage | openai | ollama

# ---- Claude (Anthropic) ----
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Voyage (embeddings) ----
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3

# ---- Ollama (local or cloud) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ---- Retrieval ----
RAG_TOP_K=6
CHUNK_TOKENS=500
CHUNK_OVERLAP_TOKENS=80
